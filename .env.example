# Server and bind
# HTTP/1.1 and HTTP/2 bind address.
VIDARAX_BIND_ADDR=127.0.0.1:8080

# Authentication
# Require x-api-key on API routes other than /v1/health.
VIDARAX_REQUIRE_API_KEY=true

# Comma-separated API keys. The code default is empty (no keys configured).
# Any non-empty value here is accepted verbatim as a valid key, so do not ship
# this file's placeholder. Uncomment and set your own keys before enabling
# VIDARAX_REQUIRE_API_KEY.
#VIDARAX_API_KEYS=

# Require x-tenant-id metadata. This does not create isolation without API keys.
VIDARAX_REQUIRE_TENANT_ID=false

# Require x-api-key for /v1/metrics.
VIDARAX_METRICS_REQUIRE_API_KEY=true

# Rate limiting
# Optional global request limit per second. Leave empty to disable.
VIDARAX_RATE_LIMIT_GLOBAL_RPS=

# Optional per-principal request limit per second. Leave empty to disable.
VIDARAX_RATE_LIMIT_TENANT_RPS=

# Maximum tracked principal buckets for the per-principal rate limiter.
VIDARAX_RATE_LIMIT_TENANT_SLOTS=2048

# CORS
# Comma-separated allowed origins. Empty means no browser origins are allowed.
VIDARAX_CORS_ALLOWED_ORIGINS=

# Inference backends
# Backend config file. Used when explicit base URLs below are not set.
VIDARAX_CONFIG=vidarax.toml

# vLLM OpenAI-compatible base URL.
VIDARAX_VLLM_BASE_URL=

# SGLang OpenAI-compatible base URL.
VIDARAX_SGLANG_BASE_URL=

# Video decode backend: auto, cpu-ffmpeg, nvdec-cuda, or mlx.
VIDARAX_DECODE_BACKEND=auto

# ffmpeg binary path.
VIDARAX_FFMPEG_PATH=ffmpeg

# ffprobe binary path.
VIDARAX_FFPROBE_PATH=ffprobe

# nvidia-smi binary path for auto-detecting NVDEC.
VIDARAX_NVIDIA_SMI_PATH=nvidia-smi

# WebRTC and streaming
# Idle TTL for active runs, in seconds. Must be in [60, 86400].
VIDARAX_STREAM_TTL_SECS=3600

# Max active runs per resolved principal. Clamped to [1, 1024].
VIDARAX_ACTIVE_STREAM_LIMIT=5

# Comma-separated STUN server URIs.
VIDARAX_WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302

# Optional TURN relay URL.
VIDARAX_WEBRTC_TURN_URL=

# Optional TURN username.
VIDARAX_WEBRTC_TURN_USERNAME=

# Optional TURN credential.
VIDARAX_WEBRTC_TURN_CREDENTIAL=

# VLM output token rate cap per WebRTC session.
VIDARAX_WEBRTC_MAX_OUTPUT_TOKENS_PER_SECOND=128

# Per-stream worker counts. Values above 1 currently clamp to 1.
VIDARAX_WEBRTC_DECODE_WORKERS=1
VIDARAX_WEBRTC_ANALYSIS_WORKERS=1
VIDARAX_WEBRTC_VLM_WORKERS=1

# Live semantic novelty. Raw JPEGs and f32 embeddings use binary TCP.
VIDARAX_NOVELTY_EMBEDDING_ADDR=
# Set 0 to disable reuse.
VIDARAX_NOVELTY_MAX_REUSE_MS=2000
VIDARAX_NOVELTY_MAX_CUMULATIVE_DRIFT=0.50
# Sample reuse decisions through the VLM for online calibration.
VIDARAX_NOVELTY_SHADOW_SAMPLE_RATE=0.01
VIDARAX_NOVELTY_EMBEDDING_TIMEOUT_MS=2000
VIDARAX_NOVELTY_REUSE_THRESHOLD=0.12

# Ingest
# Comma-separated local roots allowed for file:// and path ingest.
VIDARAX_INGEST_FILE_ROOTS=

# Allow remote HLS manifests. Keep false unless manifests are trusted.
VIDARAX_ALLOW_REMOTE_HLS=false

# Allow http:// media sources and redirects.
VIDARAX_ALLOW_INSECURE_HTTP=false

# Allow rtsp:// camera sources.
VIDARAX_ALLOW_UNENCRYPTED_RTSP=false

# Skip ffmpeg TLS verification arguments for supported live sources.
VIDARAX_ALLOW_INSECURE_TLS=false

# Transport and HTTP/3
# Transport mode: h1h2 or h3.
VIDARAX_TRANSPORT=h1h2

# HTTP/3 UDP bind address, used only when VIDARAX_TRANSPORT=h3.
VIDARAX_H3_BIND_ADDR=127.0.0.1:8443

# TLS certificate for experimental HTTP/3.
VIDARAX_H3_TLS_CERT_PATH=deploy/certs/dev.crt

# TLS private key for experimental HTTP/3.
VIDARAX_H3_TLS_KEY_PATH=deploy/certs/dev.key

# Observability
# Tracing filter used by tracing_subscriber.
RUST_LOG=info

# Optional OTLP gRPC traces endpoint.
VIDARAX_TRACES_ENDPOINT=

# Storage
# Runtime data directory. The WAL lives at ${VIDARAX_DATA_DIR}/timeline.wal.
VIDARAX_DATA_DIR=.vidarax-data

# Optional JSON file for per-tenant event and object label mapping.
VIDARAX_TENANT_LABEL_MAPS_PATH=
