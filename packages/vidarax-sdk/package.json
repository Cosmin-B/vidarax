{
  "name": "vidarax",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vidarax video analysis API",
  "keywords": [
    "video",
    "analysis",
    "sdk",
    "webrtc",
    "whip"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run tests/client.test.ts",
    "test:e2e": "vitest run tests/e2e.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cosmin-B/vidarax.git",
    "directory": "packages/vidarax-sdk"
  }
}
