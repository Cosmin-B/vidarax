VIDARAX_BIND_ADDR=127.0.0.1:8080
VIDARAX_DATA_DIR=/var/lib/vidarax
VIDARAX_CONFIG=/etc/vidarax/vidarax.toml
VIDARAX_REQUIRE_API_KEY=true
VIDARAX_API_KEYS=replace-me
VIDARAX_METRICS_REQUIRE_API_KEY=true
VIDARAX_DECODE_BACKEND=auto
VIDARAX_MEDIA_MEMORY_BUDGET_BYTES=2147483648
VIDARAX_MEDIA_WORKER_THREAD_BUDGET=16
VIDARAX_INFERENCE_GLOBAL_LIMIT=2
VIDARAX_INFERENCE_PER_PRINCIPAL_LIMIT=2
VIDARAX_INFERENCE_TOKEN_BUDGET=4096
VIDARAX_INFERENCE_BYTE_BUDGET=134217728
VIDARAX_TRIGGER_LOCAL_OUTPUT_SOCKET=/run/vidarax/trigger.sock
VIDARAX_EDGE_MANIFEST_URL=https://control.example.invalid/v1/fleet/devices/device-id/desired-manifest
VIDARAX_EDGE_MAX_ARTIFACT_BYTES=34359738368
